{
  "name": "googlemeet",
  "version": "1.2.3",
  "author": "CCWorkforce Engineers",
  "repository": "https://github.com/CCWorkforce/GiMeet",
  "main": "lib/main/index.cjs",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@rsbuild/core": "^1.7.3",
    "@rslib/core": "^0.19.6",
    "@rspack/core": "^1.7.7",
    "@tsconfig/node24": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "description": "Google Meet Reminder is a desktop application that helps you keep track of your Google Meet meetings and reminds you before they start.",
  "engineStrict": true,
  "engines": {
    "node": ">=24.14.0",
    "bun": ">=1.3.10"
  },
  "homepage": "https://github.com/CCWorkforce/GiMeet",
  "packageManager": "bun@1.3.10",
  "private": true,
  "productName": "Google Meet Reminder",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run build:main && bun run build:preload && bun run build:renderer",
    "build:main": "rslib build -c rslib.config.ts",
    "build:preload": "rslib build -c rslib.config.preload.ts",
    "build:renderer": "rsbuild build",
    "package": "bun run build && electron-builder --mac --arm64",
    "package:dir": "bun run build && electron-builder --mac --arm64 --dir",
    "typecheck": "tsc -b",
    "test": "vitest run -c vitest.workspace.ts",
    "test:watch": "vitest -c vitest.workspace.ts",
    "test:coverage": "vitest run -c vitest.workspace.ts --coverage",
    "clean": "rimraf lib dist"
  },
  "sideEffects": false,
  "type": "module"
}
