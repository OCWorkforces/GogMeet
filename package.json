{
  "name": "gogmeet",
  "version": "1.9.4",
  "author": "OCWorkforces Engineers",
  "repository": "https://github.com/OCWorkforces/GogMeet",
  "main": "lib/main/index.cjs",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@rsbuild/core": "^2.0.2",
    "@rslib/core": "^0.21.3",
    "@rspack/core": "^2.0.0",
    "@tsconfig/node24": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "authorEmail": "kennydizi@ocworkforces.com",
  "description": "GogMeet is a desktop application that helps you keep track of your Google Meet meetings and reminds you before they start.",
  "engineStrict": true,
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.12"
  },
  "homepage": "https://github.com/OCWorkforces/GogMeet",
  "packageManager": "bun@1.3.13",
  "private": true,
  "productName": "GogMeet",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run build:main && bun run build:preload && bun run build:renderer",
    "build:main": "rslib build -c rslib.config.ts",
    "build:preload": "rslib build -c rslib.config.preload.ts",
    "build:renderer": "rsbuild build",
    "package": "bun run build && electron-builder --mac",
    "package:dir": "bun run build && electron-builder --mac --dir",
    "typecheck": "tsc -b",
    "test": "vitest run -c vitest.workspace.ts",
    "test:watch": "vitest -c vitest.workspace.ts",
    "test:coverage": "vitest run -c vitest.workspace.ts --coverage",
    "clean": "rimraf lib dist",
    "lint": "eslint src/ --cache",
    "format:check": "prettier --check 'src/**/*.{ts,css}'",
    "format": "prettier --write 'src/**/*.{ts,css}'"
  },
  "sideEffects": false,
  "type": "module"
}
