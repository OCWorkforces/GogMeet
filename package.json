{
  "name": "gogmeet",
  "version": "1.5.9",
  "author": "OCWorkforces Engineers",
  "repository": "https://github.com/OCWorkforces/GogMeet",
  "main": "lib/main/index.cjs",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@rsbuild/core": "^1.7.3",
    "@rslib/core": "^0.20.0",
    "@rspack/core": "^1.7.10",
    "@tsconfig/node24": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/browser": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "authorEmail": "kennydizi@ocworkforces.com",
  "description": "GogMeet is a desktop application that helps you keep track of your Google Meet meetings and reminds you before they start.",
  "engineStrict": true,
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.11"
  },
  "homepage": "https://github.com/OCWorkforces/GogMeet",
  "packageManager": "bun@1.3.11",
  "private": true,
  "productName": "GogMeet",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run build:main && bun run build:preload && bun run build:renderer",
    "build:main": "rslib build -c rslib.config.ts",
    "build:preload": "rslib build -c rslib.config.preload.ts",
    "build:renderer": "rsbuild build",
    "package": "bun run build && electron-builder --mac",
    "package:dir": "bun run build && electron-builder --mac --dir",
    "typecheck": "tsc -b",
    "test": "vitest run -c vitest.workspace.ts",
    "test:watch": "vitest -c vitest.workspace.ts",
    "test:coverage": "vitest run -c vitest.workspace.ts --coverage",
    "clean": "rimraf lib dist"
  },
  "sideEffects": false,
  "type": "module"
}
