{
  "name": "googlemeet",
  "productName": "Google Meet Reminder",
  "version": "3.4.5",
  "description": "Google Meet Reminder is a desktop application that helps you keep track of your Google Meet meetings and reminds you before they start.",
  "private": true,
  "repository": "https://github.com/CCWorkforce/GiMeet",
  "homepage": "https://github.com/CCWorkforce/GiMeet",
  "author": "CCWorkforce",
  "packageManager": "bun@1.3.10",
  "type": "module",
  "main": "lib/main/index.cjs",
  "sideEffects": false,
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run build:main && bun run build:preload && bun run build:renderer",
    "build:main": "rslib build -c rslib.config.ts",
    "build:preload": "rslib build -c rslib.config.preload.ts",
    "build:renderer": "rsbuild build",
    "package": "bun run build && electron-builder --mac --arm64",
    "package:dir": "bun run build && electron-builder --mac --arm64 --dir",
    "typecheck": "tsc -b",
    "clean": "rimraf lib dist"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@rsbuild/core": "^1.7.3",
    "@rslib/core": "^0.19.6",
    "@rspack/core": "^1.7.6",
    "@tsconfig/node24": "^24.0.4",
    "@types/auto-launch": "^5.0.5",
    "@types/throttle-debounce": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-context-menu": "^4.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "electron-update-notifier": "^1.7.0",
    "throttle-debounce": "^5.0.2"
  },
  "engineStrict": true,
  "engines": {
    "node": ">=24.13.1",
    "bun": ">=1.3.10"
  }
}
